{
  "name": "@redesigner/daemon",
  "version": "0.0.1",
  "type": "module",
  "engines": { "node": ">=22.0.0" },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./child": { "import": "./dist/child.js", "default": "./dist/child.js" }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.typecheck.json",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:integration": "vitest run test/integration"
  },
  "dependencies": {
    "@redesigner/core": "workspace:*",
    "zod": "^3.25.0 || ^4.0.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@redesigner/mcp": "workspace:*",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
