{
  "manifest_version": 3,
  "name": "reDesigner",
  "version": "0.0.0",
  "description": "Pick a DOM element in your dev build and surface it to Claude Code via the reDesigner daemon.",
  "minimum_chrome_version": "120",
  "key": "",
  "action": {
    "default_title": "reDesigner",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "side_panel": {
    "default_path": "src/panel/index.html"
  },
  "background": {
    "service_worker": "src/sw/index.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://*.localhost/*",
        "http://[::1]/*"
      ],
      "run_at": "document_start",
      "js": ["src/content/bootstrap.ts"]
    },
    {
      "matches": [
        "http://localhost/*",
        "http://127.0.0.1/*",
        "http://*.localhost/*",
        "http://[::1]/*"
      ],
      "run_at": "document_end",
      "js": ["src/content/index.ts"]
    }
  ],
  "commands": {
    "arm-picker": {
      "suggested_key": {
        "default": "Alt+Shift+D",
        "mac": "Alt+Shift+D"
      },
      "description": "Arm picker"
    }
  },
  "permissions": ["scripting", "storage", "tabs", "sidePanel", "alarms"],
  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://*.localhost/*",
    "http://[::1]/*"
  ]
}
